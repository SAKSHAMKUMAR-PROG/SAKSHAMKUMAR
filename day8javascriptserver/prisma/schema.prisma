generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  CLIENT
  LAWYER
  ADMIN
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum MessageSender {
  USER
  ASSISTANT
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password      String
  phone         String?
  profileImage  String?

  role          UserRole @default(CLIENT)

  createdCases  Case[]   @relation("CaseClient")
  assignedCases Case[]   @relation("CaseLawyer")

  documents     Document[]
  conversations Conversation[]
  notifications Notification[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Case {
  id          String      @id @default(uuid())
  title       String
  description String

  status      CaseStatus  @default(OPEN)

  clientId    String
  client      User        @relation("CaseClient", fields: [clientId], references: [id])

  lawyerId    String?
  lawyer      User?       @relation("CaseLawyer", fields: [lawyerId], references: [id])

  documents   Document[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  title     String
  fileUrl   String

  caseId    String?
  case      Case?    @relation(fields: [caseId], references: [id])

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

model Conversation {
  id        String   @id @default(uuid())
  title     String?

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  messages  Message[]

  createdAt DateTime @default(now())
}

model Message {
  id             String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  sender         MessageSender
  content        String

  createdAt      DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())

  title     String
  message   String

  isRead    Boolean  @default(false)

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}